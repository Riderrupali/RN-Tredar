{
  "expo": {
    "name": "RN Tredar",
    "slug": "code-magic",
    "owner": "riderrupali170",
    "version": "1.0.0",
    "projectId": "1c7d2426-5b7d-4f15-8854-8e1e355c3258",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "RN_Treder",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.codemagic.trading"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0A0E1A"
      },
      "package": "com.codemagic.trading",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Chart images scan karayla gallery access lagto.",
          "cameraPermission": false
        }
      ]
    ]
  }
}

